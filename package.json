{
  "name": "pi-must-have-extension",
  "version": "0.4.4",
  "description": "RFC 2119 keyword normalizer extension for the Pi coding agent.",
  "type": "module",
  "main": "./index.ts",
  "exports": {
    ".": "./index.ts"
  },
  "files": [
    "index.ts",
    "src",
    "asset",
    "config/config.example.jsonc",
    "config/replacements.custom-sample.jsonc",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "tsconfig.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "lint": "npm run build",
    "test": "node --experimental-strip-types --test test/**/*.test.ts",
    "check": "npm run lint && npm run test"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi-coding-agent",
    "pi",
    "coding-agent",
    "rfc2119",
    "rfc8174",
    "bcp14",
    "prompt-normalization",
    "prompt-rewrite",
    "compliance",
    "jsonc"
  ],
  "author": "MasuRii",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MasuRii/pi-must-have-extension.git"
  },
  "homepage": "https://github.com/MasuRii/pi-must-have-extension#readme",
  "bugs": {
    "url": "https://github.com/MasuRii/pi-must-have-extension/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.57.0",
    "@types/node": "^25.3.5",
    "typescript": "^5.7.3"
  }
}
